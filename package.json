{
  "name": "agent-evidence-binder-skill",
  "version": "0.1.0",
  "description": "Bundle repository evidence, command output, and claims into reviewable local evidence packets.",
  "type": "module",
  "bin": {
    "agent-evidence-binder": "src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "bash scripts/validate.sh",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "local-first",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-evidence-binder-skill.git"
  },
  "files": [
    "src",
    "scripts",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-evidence-binder-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-evidence-binder-skill#readme"
}
